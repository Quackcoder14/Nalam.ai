// This is your Prisma schema for nalam.ai (Prisma v5)
// All PHI/PII fields stored as AES-256-GCM encrypted blobs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Patient ─────────────────────────────────────────────────────────────────
model Patient {
  id                  String          @id
  name_enc            String          @db.Text
  dob_enc             String          @db.Text
  gender_enc          String          @db.Text
  contact_enc         String          @db.Text
  mobile_enc          String?         @db.Text
  blood_type_enc      String          @db.Text
  allergies_enc       String          @db.Text
  consent_emergency   Boolean         @default(false)
  consent_specialist  Boolean         @default(false)
  consent_research    Boolean         @default(false)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt

  records             MedicalRecord[]
  auditLogs           AuditLog[]

  @@map("patients")
}

// ─── Medical Record ───────────────────────────────────────────────────────────
model MedicalRecord {
  id              String   @id @default(cuid())
  patient_id      String
  date            String
  type_enc        String   @db.Text
  provider_enc    String   @db.Text
  diagnosis_enc   String   @db.Text
  notes_enc       String?  @db.Text
  lab_results_enc String?  @db.Text
  created_at      DateTime @default(now())

  patient         Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, date])
  @@map("medical_records")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
model AuditLog {
  id             String   @id @default(cuid())
  patient_id     String
  clinician_enc  String   @db.Text
  reason_enc     String   @db.Text
  context_type   String
  created_at     DateTime @default(now())

  patient        Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, created_at])
  @@map("audit_logs")
}

// ─── Push Notification Subscriptions ─────────────────────────────────────────
model PushSubscription {
  id         String   @id @default(cuid())
  patient_id String?
  role       String   @default("patient")  // "patient" | "clinician"
  endpoint   String   @unique @db.Text
  keys_json  String   @db.Text
  created_at DateTime @default(now())

  @@index([patient_id])
  @@map("push_subscriptions")
}

// ─── Clinical Alerts (Active Notifications) ──────────────────────────────────
model ClinicalAlert {
  id         String   @id @default(cuid())
  patient_id String
  severity   String
  title      String   @db.Text
  message    String   @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([patient_id, is_read])
  @@map("clinical_alerts")
}
