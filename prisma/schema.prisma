// This is your Prisma schema for nalam.ai (Prisma v5)
// All PHI/PII fields stored as AES-256-GCM encrypted blobs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Patient ─────────────────────────────────────────────────────────────────
model Patient {
  id                  String          @id
  password_hash       String?
  name_enc            String          @db.Text
  dob_enc             String          @db.Text
  gender_enc          String          @db.Text
  contact_enc         String          @db.Text
  mobile_enc          String?         @db.Text
  email_enc           String?         @db.Text
  address_enc         String?         @db.Text
  city_enc            String?         @db.Text
  district_enc        String?         @db.Text
  state_enc           String?         @db.Text
  pincode_enc         String?         @db.Text
  guardian_name_enc   String?         @db.Text
  emergency_name_enc  String?         @db.Text
  emergency_relation_enc String?      @db.Text
  emergency_phone_enc String?         @db.Text
  occupation_enc      String?         @db.Text
  marital_status_enc  String?         @db.Text
  preferred_language_enc String?      @db.Text
  insurance_provider_enc String?      @db.Text
  insurance_policy_enc String?        @db.Text
  aadhaar_last4_enc   String?         @db.Text
  blood_type_enc      String          @db.Text
  allergies_enc       String          @db.Text
  chronic_conditions_enc String?      @db.Text
  current_medications_enc String?     @db.Text
  past_surgeries_enc  String?         @db.Text
  family_history_enc  String?         @db.Text
  lifestyle_notes_enc String?         @db.Text
  consent_emergency   Boolean         @default(false)
  consent_specialist  Boolean         @default(false)
  consent_research    Boolean         @default(false)
  abha_id_enc         String?         @db.Text
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt

  records             MedicalRecord[]
  auditLogs           AuditLog[]
  appointments        Appointment[]
  messages            ChatMessage[]
  files               PatientFile[]
  otpRequests         RecordsOtp[]
  intakeRequests      IntakeRequest[]
  familyLinks         FamilyPatientLink[]

  @@map("patients")

}

// ─── Medical Record ───────────────────────────────────────────────────────────
model MedicalRecord {
  id              String   @id @default(cuid())
  patient_id      String
  date            String
  type_enc        String   @db.Text
  provider_enc    String   @db.Text
  diagnosis_enc   String   @db.Text
  notes_enc       String?  @db.Text
  lab_results_enc String?  @db.Text
  department_enc  String?  @db.Text
  doctor_name_enc String?  @db.Text
  medications_enc String?  @db.Text
  procedures_enc  String?  @db.Text
  vitals_json_enc String?  @db.Text
  follow_up_date  String?
  attachments_json_enc String? @db.Text
  created_at      DateTime @default(now())

  patient         Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, date])
  @@map("medical_records")
}

// ─── Doctor ────────────────────────────────────────────────────────────────────
model Doctor {
  id                    String   @id
  password_hash         String?
  full_name_enc         String   @db.Text
  gender_enc            String?  @db.Text
  dob_enc               String?  @db.Text
  mobile_enc            String?  @db.Text
  email_enc             String?  @db.Text
  registration_number   String
  registration_council  String
  registration_year     String?
  qualification_enc     String   @db.Text
  specialty             String
  department            String
  designation           String?
  hospital              String
  experience_years      Int?
  languages_json        String?  @db.Text
  consultation_modes_json String? @db.Text
  available_days_json   String?  @db.Text
  time_slots_json       String?  @db.Text
  room_number_enc       String?  @db.Text
  address_enc           String?  @db.Text
  district              String?
  state                 String?   @default("Tamil Nadu")
  pincode               String?
  status                String   @default("active")
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@unique([registration_council, registration_number])
  @@index([hospital, specialty, status])
  @@map("doctors")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
model AuditLog {
  id             String   @id @default(cuid())
  patient_id     String
  clinician_enc  String   @db.Text
  reason_enc     String   @db.Text
  context_type   String
  created_at     DateTime @default(now())

  patient        Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, created_at])
  @@map("audit_logs")
}

// ─── Push Notification Subscriptions ─────────────────────────────────────────
model PushSubscription {
  id         String   @id @default(cuid())
  patient_id String?
  role       String   @default("patient")  // "patient" | "clinician"
  endpoint   String   @unique @db.Text
  keys_json  String   @db.Text
  created_at DateTime @default(now())

  @@index([patient_id])
  @@map("push_subscriptions")
}

// ─── Clinical Alerts (Active Notifications) ──────────────────────────────────
model ClinicalAlert {
  id         String   @id @default(cuid())
  patient_id String
  severity   String
  title      String   @db.Text
  message    String   @db.Text
  is_read    Boolean  @default(false)
  hospital   String?  // Hospital/branch that created the alert (for per-desk routing)
  broadcast  Boolean  @default(false) // If true, alert is shown to all hospitals (e.g., anomalies)
  acknowledged Boolean @default(false) // Whether the alert has been acknowledged as resolved
  acknowledged_by String? // Hospital/branch that acknowledged the alert
  acknowledged_at DateTime? // When the alert was acknowledged
  created_at DateTime @default(now())

  @@index([patient_id, is_read])
  @@index([hospital, is_read])
  @@map("clinical_alerts")
}

// ─── Appointments ────────────────────────────────────────────────────────────
model Appointment {
  id                        String    @id @default(cuid())
  patient_id                String
  doctor_id                 String
  doctor_name               String
  doctor_specialty          String
  hospital                  String
  date                      String
  time                      String?
  reason_enc                String    @db.Text
  urgency                   String
  vitals_json               String?   @db.Text
  attachments_json          String?   @db.Text
  status                    String    @default("pending")
  ai_summary_enc            String?   @db.Text
  hdesk_note_enc            String?   @db.Text
  reschedule_reason_enc     String?   @db.Text
  reschedule_proposed_date  String?
  reschedule_proposed_time  String?
  session_notes_enc         String?   @db.Text
  session_prescriptions_enc String?   @db.Text
  session_documents_enc     String?   @db.Text
  session_started_at        DateTime?
  finished_at               DateTime?
  created_at                DateTime  @default(now())
  approved_at               DateTime?
  scheduled_at              DateTime?
  pre_reschedule_status     String?

  patient                   Patient   @relation(fields: [patient_id], references: [id])

  @@index([patient_id, status])
  @@map("appointments")
}

// ─── Chat Messages ───────────────────────────────────────────────────────────
model ChatMessage {
  id           String   @id @default(cuid())
  patient_id   String
  hospital     String
  sender       String   // "patient" | "desk"
  type         String   @default("text") // "text", "voice", "image", "file"
  content_enc  String   @db.Text
  staff_id     String?  // The identity of the staff member who sent this message (if desk/clinician)
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  patient      Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, hospital])
  @@map("chat_messages")
}

// ─── Patient Files (Records Gallery) ─────────────────────────────────────────
model PatientFile {
  id               String   @id @default(cuid())
  patient_id       String
  filename_enc     String   @db.Text
  file_type        String   // "image" | "pdf" | "document"
  file_data_enc    String   @db.Text  // base64 encrypted
  source           String   @default("manual") // "manual" | "document_scanner"
  uploaded_by      String   // patient_id or staff_id
  file_size_bytes  Int      @default(0)
  created_at       DateTime @default(now())

  patient          Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, created_at])
  @@map("patient_files")
}

// ─── Records OTP ──────────────────────────────────────────────────────────────
model RecordsOtp {
  id            String   @id @default(cuid())
  patient_id    String
  otp_hash      String   // SHA-256 hashed OTP
  requestor_id  String   // clinician or hdesk staff ID
  requestor_name String  @default("")
  expires_at    DateTime
  used          Boolean  @default(false)
  created_at    DateTime @default(now())

  patient       Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, expires_at])
  @@map("records_otps")
}

// ─── Chatbot Conversations ─────────────────────────────────────────────────────
model ChatbotConversation {
  id          String   @id @default(cuid())
  user_id     String   // patient_id or clinician_id
  user_role   String   // 'patient' or 'clinician'
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  messages    ChatbotMessage[]

  @@index([user_id, user_role])
  @@map("chatbot_conversations")
}

model ChatbotMessage {
  id              String   @id @default(cuid())
  conversation_id String
  role            String   // 'user' or 'assistant'
  content         String   @db.Text
  created_at      DateTime @default(now())

  conversation    ChatbotConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("chatbot_messages")
}

// ─── Hospital Desk Staff ───────────────────────────────────────────────────────
model HospitalDeskStaff {
  id            String   @id
  username      String   @unique // e.g., apollo@nalam.ai
  staff_id      String   @unique // e.g., APOLLO-001
  password_hash String
  name_enc      String   @db.Text
  branch        String   // e.g., Apollo Hospital
  role          String   @default("staff") // "staff" | "manager"
  status        String   @default("active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([branch, status])
  @@map("hospital_desk_staff")
}

// ─── Intake Requests (Pre-Consultation Symptom Recording) ──────────────────────
model IntakeRequest {
  id                 String   @id @default(cuid())
  patient_id         String
  hospital           String
  status             String   @default("pending") // "pending", "submitted", "routed", "cleared"
  symptoms_text_enc  String?  @db.Text
  questionnaire_json_enc String? @db.Text
  routed_doctor_id   String?
  ai_summary_enc     String?  @db.Text
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  patient            Patient  @relation(fields: [patient_id], references: [id])

  @@index([patient_id, status])
  @@index([hospital, status])
  @@index([routed_doctor_id, status])
  @@map("intake_requests")
}

// ─── Rook Wearable Vitals (Live via Webhook) ─────────────────────────────────
model RookVitals {
  id          String   @id @default(cuid())
  patient_id  String
  hr          Int?     // Heart rate (BPM)
  spo2        Int?     // Blood oxygen (%)
  resp        Int?     // Respiration rate (breaths/min)
  temp        Float?   // Temperature (°C)
  sys         Int?     // Systolic BP (mmHg)
  dia         Int?     // Diastolic BP (mmHg)
  steps       Int?     // Step count
  calories    Int?     // Calories burned
  data_source String?  // e.g., "Fitbit", "Garmin"
  recorded_at DateTime // When the device recorded this
  created_at  DateTime @default(now())

  @@index([patient_id, recorded_at])
  @@map("rook_vitals")
}

// ─── Family Account ────────────────────────────────────────────────────────────
model FamilyAccount {
  id            String   @id @default(cuid())
  email         String   @unique
  password_hash String
  name_enc      String   @db.Text
  mobile_enc    String?  @db.Text
  dob_enc       String?  @db.Text
  gender_enc    String?  @db.Text
  address_enc   String?  @db.Text
  city_enc      String?  @db.Text
  state_enc     String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  links         FamilyPatientLink[]

  @@map("family_accounts")
}

// ─── Family ↔ Patient Link (with consent state) ────────────────────────────────
model FamilyPatientLink {
  id               String    @id @default(cuid())
  family_id        String
  patient_id       String
  nickname_enc     String?   @db.Text
  relation_enc     String?   @db.Text
  consent_status   String    @default("pending")  // "pending" | "approved" | "revoked"
  consented_at     DateTime?
  requested_at     DateTime  @default(now())
  can_view_records Boolean   @default(false)
  invite_code      String?   // 6-digit OTP sent to patient
  invite_code_expires_at DateTime?

  family           FamilyAccount @relation(fields: [family_id], references: [id], onDelete: Cascade)
  patient          Patient       @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@unique([family_id, patient_id])
  @@index([patient_id, consent_status])
  @@map("family_patient_links")
}
