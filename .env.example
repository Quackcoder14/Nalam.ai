# Environment Configuration — nalam.ai
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL="mysql://root:YOUR_MYSQL_PASSWORD@localhost:3306/nalamdb"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte (256-bit) hex key for AES-256-GCM patient data encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_64_char_hex_key_here"

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Groq API key for biographer synthesis, OCR, and intervention analysis
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ── ML Service ────────────────────────────────────────────────────────────────
# URL of the Python FastAPI ML service (default: localhost)
ML_SERVICE_URL="http://localhost:8001"
